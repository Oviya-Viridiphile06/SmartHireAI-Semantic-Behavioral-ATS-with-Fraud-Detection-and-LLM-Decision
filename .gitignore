__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
env/
*.env
.env.*   # Sometimes dotenv creates environment-specific files

# Databases
*.db
*.sqlite3

# OS / editor files
.DS_Store
Thumbs.db
